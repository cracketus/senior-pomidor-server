# Local development example. Production uses /srv/secrets/senior-pomidor/runtime.env.
# Replace every CHANGE_ME value. URL-encode reserved characters in DATABASE_URL.
APP_IMAGE=senior-pomidor-server:dev
POSTGRES_DB=senior_pomidor
POSTGRES_USER=senior_pomidor_app
POSTGRES_PASSWORD=CHANGE_ME_DATABASE_PASSWORD
DATABASE_URL=postgresql+psycopg://senior_pomidor_app:CHANGE_ME_DATABASE_PASSWORD@postgres:5432/senior_pomidor
# Address assigned to the trusted LAN interface (not 0.0.0.0).
LAN_BIND_ADDRESS=127.0.0.1
POSTGRES_BIND_ADDRESS=127.0.0.1
API_HOST=0.0.0.0
API_PORT=8000
API_PUBLISHED_PORT=8000
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_PUBLISHED_PORT=1883
MQTT_TOPIC_PREFIX=senior-pomidor
# MQTT_USERNAME=
# MQTT_PASSWORD=
POSTGRES_PUBLISHED_PORT=5432
PHOTO_STORAGE_DIR=data/photos
PHOTO_MAX_BYTES=26214400
# PHOTO_UPLOAD_TOKEN=
# TELEMETRY_UPLOAD_TOKEN=
API_DOCS_ENABLED=true
# Local bind-mount paths. Production uses the fixed /srv paths in deploy/senior-pomidor.env.example.
POSTGRES_DATA_DIR=./data/postgres
GRAFANA_DATA_DIR=./data/grafana
MOSQUITTO_DATA_DIR=./data/mosquitto
PHOTO_DATA_DIR=./data/photos
ESTIMATOR_PRIVATE_DATA_DIR=./data/estimator-private
OLLAMA_DATA_DIR=./data/ollama
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_ADMIN_PASSWORD
GRAFANA_PUBLISHED_PORT=3000
GRAFANA_DB_USER=grafana_reader
GRAFANA_DB_PASSWORD=CHANGE_ME_GRAFANA_READER_PASSWORD
GRAFANA_CLOUD_EXPORT_ENABLED=false
# GRAFANA_CLOUD_REMOTE_WRITE_URL=
# GRAFANA_CLOUD_INSTANCE_ID=
# GRAFANA_CLOUD_API_TOKEN=
GRAFANA_CLOUD_EXPORT_INTERVAL_SECONDS=60
GRAFANA_CLOUD_EXPORT_LOOKBACK_MINUTES=10
STATE_ESTIMATOR_ENABLED=true
STATE_ESTIMATOR_TIMEZONE=Europe/Vienna
STATE_ESTIMATOR_PRIVATE_LOG_DIR=data/private
STATE_ESTIMATOR_PUBLIC_LOG_DIR=data/public
STATE_ESTIMATOR_REPLAY_ENABLED=false

# Optional daily tomato story stack:
# docker compose -f docker-compose.yml -f docker-compose.dev.yml --profile daily-story up -d
OLLAMA_IMAGE=ollama/ollama:0.31.1
OLLAMA_PUBLISHED_PORT=11434
DAILY_STORY_NODE_ID=pi-001
DAILY_STORY_SCHEDULE_TIME=09:00
DAILY_STORY_TIMEZONE=Europe/Vienna
DAILY_STORY_LOOKBACK_HOURS=24
DAILY_STORY_POLL_INTERVAL_SECONDS=60
DAILY_STORY_MAX_ATTEMPTS=3
DAILY_STORY_RETRY_DELAY_MINUTES=15
DAILY_STORY_STALE_AFTER_MINUTES=15
DAILY_STORY_SYSTEM_PROMPT_PATH=config/daily_story/system.txt
DAILY_STORY_USER_PROMPT_PATH=config/daily_story/user.txt
DAILY_STORY_ENVIRONMENT_CONTEXT_PATH=config/daily_story/environment.json
DAILY_STORY_MAX_CONTEXT_CHARS=16000
DAILY_STORY_MAX_ENVIRONMENT_CONTEXT_CHARS=8000
DAILY_STORY_MEMORY_ENTRIES=7
DAILY_STORY_OLLAMA_HOST=http://ollama:11434
DAILY_STORY_OLLAMA_MODEL=llama3.2:3b
DAILY_STORY_OLLAMA_TIMEOUT_SECONDS=120
DAILY_STORY_OLLAMA_KEEP_ALIVE=0
DAILY_STORY_OLLAMA_REQUEST_RETRIES=3
DAILY_STORY_OLLAMA_OPTIONS_JSON={"temperature":0.4,"top_p":0.9,"top_k":40,"num_ctx":4096,"num_predict":2048,"repeat_penalty":1.1,"seed":42}
