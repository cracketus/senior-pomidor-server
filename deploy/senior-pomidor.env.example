# Production template. Install as /srv/secrets/senior-pomidor/runtime.env
# owned by root:root with mode 0600.
APP_IMAGE=ghcr.io/cracketus/senior-pomidor-server:vX.Y.Z
COMPOSE_PROFILES=cloud-export
PLATFORM_DOCKER_NETWORK=srv-platform

POSTGRES_DB=senior_pomidor
POSTGRES_USER=senior_pomidor_app
POSTGRES_PASSWORD=CHANGE_ME_DATABASE_PASSWORD
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://senior_pomidor_app:CHANGE_ME_URL_ENCODED_DATABASE_PASSWORD@postgres:5432/senior_pomidor

# Change to the new server's reserved LAN IPv4 address before production startup.
LAN_BIND_ADDRESS=127.0.0.1
API_PUBLISHED_PORT=8000
MQTT_PUBLISHED_PORT=1883

PHOTO_UPLOAD_TOKEN=CHANGE_ME_EXISTING_PHOTO_TOKEN
TELEMETRY_UPLOAD_TOKEN=CHANGE_ME_EXISTING_TELEMETRY_TOKEN
API_DOCS_ENABLED=false
GRAFANA_CLOUD_EXPORT_ENABLED=true
GRAFANA_CLOUD_REMOTE_WRITE_URL=CHANGE_ME
GRAFANA_CLOUD_INSTANCE_ID=CHANGE_ME
GRAFANA_CLOUD_API_TOKEN=CHANGE_ME

MOSQUITTO_DATA_DIR=/srv/apps/senior-pomidor/data/private/mosquitto
PHOTO_DATA_DIR=/srv/apps/senior-pomidor/data/public/photos
ESTIMATOR_PRIVATE_DATA_DIR=/srv/logs/senior-pomidor/estimator-private

STATE_ESTIMATOR_ENABLED=true
STATE_ESTIMATOR_TIMEZONE=Europe/Vienna
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_TOPIC_PREFIX=senior-pomidor
# MQTT remains anonymous during migration; leave these unset.
MQTT_USERNAME=
MQTT_PASSWORD=

# Optional app-owned story worker. Add daily-story to COMPOSE_PROFILES only
# after the platform administrator provisions this model in shared Ollama.
DAILY_STORY_OLLAMA_HOST=http://ollama:11434
DAILY_STORY_OLLAMA_MODEL=llama3.2:3b
