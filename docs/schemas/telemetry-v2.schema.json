{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "senior-pomidor.edge.telemetry.v2",
  "type": "object",
  "required": ["schema_version", "device_id", "timestamp_utc"],
  "properties": {
    "schema_version": {"const": "senior-pomidor.edge.telemetry.v2"},
    "device_id": {"type": "string"},
    "timestamp_utc": {"type": "string", "pattern": "Z$"},
    "pods": {"type": ["array", "object"]},
    "pod_readings": {"type": ["array", "object"]},
    "plant": {"type": "object"},
    "system_health": {
      "type": "object",
      "properties": {
        "rpi_core": {"type": "object"},
        "pod_1_hardware": {"type": "object"},
        "errors": {"type": "array"},
        "network": {
          "type": "object",
          "properties": {
            "wifi_connected": {"type": "boolean"},
            "interface_up": {"type": "boolean"},
            "default_gateway_reachable": {"type": "boolean"},
            "dns_resolution_ok": {"type": "boolean"},
            "internet_reachable": {"type": "boolean"},
            "active_profile_present": {"type": "boolean"},
            "preferred_profile_present": {"type": "boolean"},
            "ssid": {"type": "string"},
            "ip_address": {"type": "string"},
            "last_recovery_action": {"type": "string"},
            "last_recovery_result": {"type": "string"},
            "last_recovery_at_utc": {"type": "string"},
            "wifi_profile_count": {"type": "integer"},
            "last_recovery_exit_code": {"type": "integer"}
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
