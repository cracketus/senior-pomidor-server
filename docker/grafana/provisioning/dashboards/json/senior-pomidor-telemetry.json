          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT DISTINCT ON (device_id, pod_key)\n  timestamp_utc,\n  received_at,\n  device_id,\n  pod_key,\n  enabled,\n  soil_moisture_percent,\n  soil_temperature_c,\n  air_temperature_c,\n  air_humidity_percent,\n  air_pressure_hpa,\n  light_lux,\n  leaf_temp_c\nFROM telemetry_pod_readings_flat\nWHERE $__timeFilter(timestamp_utc)\n  AND ('${device_id:csv}' = 'All' OR device_id IN (${device_id:sqlstring}))\n  AND ('${pod_key:csv}' = 'All' OR pod_key IN (${pod_key:sqlstring}))\nORDER BY device_id, pod_key, timestamp_utc DESC",
          "refId": "A"
        }
      ],
      "title": "Latest Telemetry By Pod",
      "type": "table"
    },
