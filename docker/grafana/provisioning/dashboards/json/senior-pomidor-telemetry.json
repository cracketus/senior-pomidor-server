          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH latest AS (\n  SELECT DISTINCT ON (node_id)\n    node_id,\n    ts,\n    payload_jsonb\n  FROM sensor_health_snapshots\n  WHERE $__timeFilter(ts)\n    AND ('${device_id:csv}' = 'All' OR node_id IN (${device_id:sqlstring}))\n  ORDER BY node_id, ts DESC\n)\nSELECT\n  latest.ts AS time,\n  latest.node_id,\n  latest.payload_jsonb ->> 'overall_status' AS overall_status,\n  sensor ->> 'sensor_id' AS sensor_id,\n  sensor ->> 'sensor_type' AS sensor_type,\n  sensor ->> 'status' AS status,\n  nullif(sensor ->> 'confidence', '')::double precision AS confidence,\n  sensor ->> 'reason' AS reason\nFROM latest\nCROSS JOIN LATERAL jsonb_array_elements(coalesce(latest.payload_jsonb -> 'sensors', '[]'::jsonb)) AS sensor\nORDER BY latest.node_id, sensor_id",
          "refId": "A"
        }
      ],
