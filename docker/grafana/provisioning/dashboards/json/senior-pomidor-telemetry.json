          "rawSql": "SELECT\n  captured_at_utc,\n  device_id,\n  photo_id,\n  sharpness_score,\n  content_type,\n  file_size_bytes,\n  received_at,\n  concat('/api/v1/photos/', photo_id) AS photo_api_path\nFROM photos\nWHERE $__timeFilter(captured_at_utc)\n  AND ('${device_id:csv}' = 'All' OR device_id IN (${device_id:sqlstring}))\nORDER BY captured_at_utc DESC\nLIMIT 50",
